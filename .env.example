# ============================================
# Content AI Generator — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- Supabase (Database + Auth + Storage) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (Transactional Email) ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Upstash Redis (Cache + Rate Limiting) ---
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx

# --- Upstash QStash (Background Jobs) ---
QSTASH_TOKEN=xxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# --- Sentry (Error Tracking) ---
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- PostHog (Analytics) ---
POSTHOG_API_KEY=phx_xxx

# --- OpenRouter (AI/LLM) ---
OPENROUTER_API_KEY=sk-or-v1-xxx

# --- Serper.dev (Web Search) ---
SERPER_API_KEY=xxx

# --- ntfy (Push Notifications) ---
NTFY_TOPIC=your-topic

# --- Other ---
BEEHIIV_PUB_ID=pub_xxx
FAL_KEY=xxx

# --- Default User (set by setup_db.py) ---
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000

# --- App Config ---
FLASK_ENV=production
FLASK_SECRET_KEY=generate-a-random-64-char-string-here
ENCRYPTION_KEY=generate-a-32-byte-base64-key-here
